# VHS tape for the Mercado Público (Chile) showcase.
#   brew install vhs && npm install
#   vhs examples/demo-cl.tape   # -> examples/demo-cl.gif, examples/demo-cl.mp4

Output examples/demo-cl.gif
Output examples/demo-cl.mp4

Set Shell "zsh"
Set FontSize 15
Set Width 1300
Set Height 820
Set Padding 20
Set Theme "Catppuccin Mocha"
Set TypingSpeed 55ms

Hide
Type "clear"
Enter
Show

Type "npm run demo:cl"
Sleep 700ms
Enter
Sleep 18s
